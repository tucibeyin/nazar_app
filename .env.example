# Backend ortam değişkenleri
# Bu dosyayı .env olarak kopyalayıp doldurun: cp .env.example .env

# İzin verilen origin'ler (virgülle ayrılmış)
# Prod: https://nazar.aracabak.com
ALLOWED_ORIGINS=http://localhost,https://nazar.aracabak.com

# Rate limiting (slowapi formatı)
RATE_LIMIT=30/minute

# API anahtarı — boş bırakılırsa endpoint herkese açık olur.
# Üretim ortamında mutlaka doldurun:  openssl rand -hex 32
API_KEY=

# Sunucu
HOST=0.0.0.0
PORT=8000
