            <objects>
                <viewController id="01J-lp-oVM" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="Ze5-6b-2t3">
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <!-- Top gold accent band -->
                            <view opaque="NO" contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="top-band-01">
                                <color key="backgroundColor" red="0.78823529411764703" green="0.65882352941176463" blue="0.29803921568627451" alpha="0.30" colorSpace="custom" customColorSpace="sRGB"/>
                                <constraints>
                                    <constraint firstAttribute="height" constant="36" id="top-band-h"/>
                                </constraints>
                            </view>
                            <!-- Bottom gold accent band -->
                            <view opaque="NO" contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="bot-band-01">
                                <color key="backgroundColor" red="0.78823529411764703" green="0.65882352941176463" blue="0.29803921568627451" alpha="0.30" colorSpace="custom" customColorSpace="sRGB"/>
                                <constraints>
                                    <constraint firstAttribute="height" constant="36" id="bot-band-h"/>
                                </constraints>
                            </view>
