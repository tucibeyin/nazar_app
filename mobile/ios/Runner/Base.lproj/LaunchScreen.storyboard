                            <label opaque="NO" userInteractionEnabled="NO" contentMode="center" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ" textAlignment="center" lineBreakMode="middleTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="bismillah-lbl">
                                <fontDescription key="fontDescription" type="system" pointSize="24"/>
                                <color key="textColor" red="0.78823529411764703" green="0.65882352941176463" blue="0.29803921568627451" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <!-- App title -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="center" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="NAZAR  &amp;  FERAHLAMA" textAlignment="center" lineBreakMode="middleTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="title-lbl">
                                <fontDescription key="fontDescription" type="system" pointSize="11"/>
                                <color key="textColor" red="0.10588235294117647" green="0.29411764705882354" blue="0.24313725490196078" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                            </label>
                        </subviews>
                        <!-- Parchment background: kBg = 0xFFF3E8CE -->
                        <color key="backgroundColor" red="0.95294117647058823" green="0.90980392156862744" blue="0.80784313725490196" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                        <constraints>
                            <!-- Top band pinned to top -->
                            <constraint firstItem="top-band-01" firstAttribute="top" secondItem="Ze5-6b-2t3" secondAttribute="top" id="tb-top"/>
                            <constraint firstItem="top-band-01" firstAttribute="leading" secondItem="Ze5-6b-2t3" secondAttribute="leading" id="tb-lead"/>
                            <constraint firstItem="top-band-01" firstAttribute="trailing" secondItem="Ze5-6b-2t3" secondAttribute="trailing" id="tb-trail"/>
                            <!-- Bottom band pinned to bottom -->
